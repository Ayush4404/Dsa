            }
            else if(arr[mid]==1){//use else if statements not all if
                mid++;
            }
            else if(arr[mid]==2){
                int b=arr[mid];
                arr[mid]=arr[high];
                arr[high]=b;
                high--;
            }
        }
    }
};

