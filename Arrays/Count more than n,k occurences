class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int n=nums.size();
        int freq=0,ans=0;
        for(int i=0;i<n;i++){
            if(freq==0){
                ans=nums[i];
            }
            if(ans==nums[i]){
                freq++;
            }
            else{
                freq--;
            }
        }
        return ans;
        
    }
};

count more than n/k using unordered map
class Solution {
public:
    int countOccurence(vector<int>& arr, int k) {

        int count = 0;
        unordered_map<int, int> freq;

        // Count frequency of each element
        for (int x : arr) {
            freq[x]++;
        }

        // Count elements occurring more than n/k times
        for (auto it : freq) {
            if (it.second > arr.size() / k) {
                count++;
            }
        }

        return count;
    }
};
