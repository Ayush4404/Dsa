#include <iostream>
using namespace std;
 void swap(int &a,int &b){
        int temp=a;
        a=b;
        b=temp;
    }
    void bubbleSort(int arr[],int n){
        for(int i=0;i<n-1;i++){
            bool isSwap=false;
            for(int j=0;j<n-i-1;j++){
                if(arr[j]>arr[j+1]){
                    swap(arr[j],arr[j+1]);
                    isSwap=true;
                }
            }
            if(!isSwap){
                return;
            }
        }
    }
int main() {
   
    int n=5;
    int arr[]={4,1,5,2,3};
    bubbleSort(arr,n);
    for(int i=0;i<n;i++){
        cout<<arr[i];
    }
    return 0;

    return 0;
}
time comp is O(n^2) in all cases

