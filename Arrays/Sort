insertion sort
// Online C++ compiler to run C++ program online
#include <iostream>
using namespace std;
    void insertionSort(int arr[],int n){
        for(int i=1;i<n;i++){
            int curr=arr[i],prev=i-1;
            while(prev>=0&&arr[prev]>curr){
                arr[prev+1]=arr[prev];
                prev--;
            }
            arr[prev+1]=curr;
        }
    }
int main() {
   
    int n=5;
    int arr[]={4,1,5,2,3};
    insertionSort(arr,n);
    for(int i=0;i<n;i++){
        cout<<arr[i];
    }
    return 0;
}
best O(n)
avg and worst O(n^2);
