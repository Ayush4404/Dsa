// Online C++ compiler to run C++ program online
#include <iostream>
using namespace std;
 void swap(int &a,int &b){
        int temp=a;
        a=b;
        b=temp;
    }
    void selectionSort(int arr[],int n){
        for(int i=0;i<n-1;i++){
            int small=i;
            for(int j=i+1;j<n;j++){
                if(arr[j]<arr[small]){
                    small=j;
                }
            }
            swap(arr[i],arr[small]);
            
        }
    }
