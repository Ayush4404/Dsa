// Online C++ compiler to run C++ program online
#include <iostream>
#include<climits>
using namespace std;
int maxSum(int mat[][3],int row,int col){
    int maxS=INT_MIN;
    for(int i=0;i<row;i++){
        int sum=0;
        for(int j=0;j<col;j++){
            sum+=mat[i][j];
        }
        maxS=max(sum,maxS);
    }
    return maxS;
}
int main() {
    int matrix[3][3]={{1,2,3},{4,5,6},{7,8,9}};
    int rows=4,col=3;
    cout<<maxSum(matrix,rows,col);
    
    return 0;
}
